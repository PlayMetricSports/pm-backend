# Database Configuration
MONGODB_URI=mongodb://localhost:27017/pm-backend-test

# Server Configuration
BACKEND_PORT=5000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here

# Redis Configuration (Optional for tests)
